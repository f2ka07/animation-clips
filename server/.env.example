# Wan 2.2 inference server
# Tuned for AWS EC2 g5.xlarge (1x NVIDIA A10G, 24 GB VRAM)

WAN_ROOT=/opt/wan
WAN_TASK=ti2v-5B
WAN_CKPT_DIR=/models/Wan2.2-TI2V-5B
WAN_OFFLOAD_MODEL=true
WAN_CONVERT_MODEL_DTYPE=true
WAN_T5_CPU=true
WAN_DEFAULT_SIZE=832*480

# T2V-A14B needs more VRAM than a g5.xlarge A10G (24 GB). Only try on larger instances:
# WAN_TASK=t2v-A14B
# WAN_CKPT_DIR=/models/Wan2.2-T2V-A14B
# WAN_T5_CPU=true

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
PUBLIC_BASE_URL=http://ec2-xx-xx-xx-xx.us-east-1.compute.amazonaws.com:8000
OUTPUT_DIR=/data/videos
OUTPUT_MODE=url
API_AUTH_TOKEN=

# Optional S3 output (OUTPUT_MODE=s3)
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_PREFIX=videos

# Job queue
MAX_CONCURRENT_JOBS=1

# Status strings (match wan-stick-clips CLI .env)
STATUS_IN_QUEUE=IN_QUEUE
STATUS_IN_PROGRESS=IN_PROGRESS
STATUS_COMPLETED=COMPLETED
STATUS_FAILED=FAILED
