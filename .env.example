# Provider
PROVIDER=runpod

# RunPod connection
RUNPOD_API_KEY=
RUNPOD_MODE=serverless

# Pod mode (RUNPOD_MODE=pod)
API_PROTOCOL=http
POD_HOST=
POD_PORT=8000

# Serverless mode (RUNPOD_MODE=serverless)
RUNPOD_ENDPOINT_ID=
SERVERLESS_BASE_URL=https://api.runpod.ai/v2

# API transport
API_TYPE=rest
API_GENERATE_PATH=/run
API_STATUS_PATH=/status
AUTH_HEADER_NAME=Authorization
AUTH_HEADER_PREFIX=Bearer
USE_AUTH_HEADER=true
REQUEST_WRAPPER_KEY=input
POLLING_ENABLED=true

# Response field mapping
JOB_ID_FIELD=id
STATUS_FIELD=status
OUTPUT_FIELD=output
ERROR_FIELD=error
STATUS_COMPLETED=COMPLETED
STATUS_FAILED=FAILED
STATUS_IN_QUEUE=IN_QUEUE
STATUS_IN_PROGRESS=IN_PROGRESS
VIDEO_URL_FIELD=video_url
VIDEO_BASE64_FIELD=video_base64

# Model metadata
MODEL_FAMILY=wan
MODEL_BACKEND=wan
MODEL_NAME=wan2.2
MODEL_TASK=t2v
MODEL_VERSION=v43
MODEL_INCLUDE_IN_PAYLOAD=false
MODEL_FAMILY_FIELD=model_family
MODEL_NAME_FIELD=model_name
MODEL_TASK_FIELD=model_task
MODEL_VERSION_FIELD=model_version

# Request payload field mapping
PROMPT_FIELD=prompt
NEGATIVE_PROMPT_FIELD=negative_prompt
WIDTH_FIELD=width
HEIGHT_FIELD=height
FPS_FIELD=fps
DURATION_FIELD=duration_seconds
STEPS_FIELD=steps
CFG_FIELD=cfg
SEED_FIELD=seed

# Video defaults
WIDTH=832
HEIGHT=480
FPS=16
DURATION=5
STEPS=25
CFG=5
SEED=-1

# Polling
POLL_INTERVAL=5
TIMEOUT=600

# Local project paths
OUTPUT_DIR=outputs
CLIP_INDEX=data/clips_index.json
