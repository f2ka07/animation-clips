# Provider (aws | minimax | runpod)
PROVIDER=runpod

# RunPod MiniMax Hailuo (matches D:\VideoApp\API curl example)
RUNPOD_API_KEY=
RUNPOD_MODE=serverless
RUNPOD_ENDPOINT_ID=minimax-hailuo-02-std
RUNPOD_PAYLOAD_PROFILE=minimax_hailuo
SERVERLESS_BASE_URL=https://api.runpod.ai/v2
REQUEST_WRAPPER_KEY=input
PROMPT_FIELD=prompt
DURATION_FIELD=duration
MINIMAX_HAILUO_ENABLE_PROMPT_EXPANSION=false
MINIMAX_HAILUO_EXPANSION_FIELD=enable_prompt_expansion
# Optional: override default channel protagonist wording (see PROMPT.md)
# CHARACTER_DESCRIPTION=
POLLING_ENABLED=true
JOB_ID_FIELD=id
STATUS_FIELD=status
OUTPUT_FIELD=output
VIDEO_URL_FIELD=result

# AWS connection (set PROVIDER=aws to use)
AWS_MODE=rest
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_SAGEMAKER_ENDPOINT_NAME=

# REST API (EC2 GPU, ALB, or API Gateway) - AWS_MODE=rest
API_PROTOCOL=https
API_HOST=
API_PORT=8000
API_AUTH_TOKEN=

# API transport
API_TYPE=rest
API_GENERATE_PATH=/generate
API_STATUS_PATH=/status
AUTH_HEADER_NAME=Authorization
AUTH_HEADER_PREFIX=Bearer
USE_AUTH_HEADER=false
REQUEST_WRAPPER_KEY=
POLLING_ENABLED=true

# Response field mapping
JOB_ID_FIELD=id
STATUS_FIELD=status
OUTPUT_FIELD=output
ERROR_FIELD=error
STATUS_COMPLETED=COMPLETED
STATUS_FAILED=FAILED
STATUS_IN_QUEUE=IN_QUEUE
STATUS_IN_PROGRESS=IN_PROGRESS
VIDEO_URL_FIELD=video_url
VIDEO_BASE64_FIELD=video_base64
VIDEO_S3_FIELD=video_s3_uri

# Model metadata
MODEL_FAMILY=wan
MODEL_BACKEND=wan
MODEL_NAME=wan2.2
MODEL_TASK=t2v
MODEL_VERSION=ti2v-5B
MODEL_INCLUDE_IN_PAYLOAD=false
MODEL_FAMILY_FIELD=model_family
MODEL_NAME_FIELD=model_name
MODEL_TASK_FIELD=model_task
MODEL_VERSION_FIELD=model_version

# Request payload field mapping
PROMPT_FIELD=prompt
NEGATIVE_PROMPT_FIELD=negative_prompt
WIDTH_FIELD=width
HEIGHT_FIELD=height
FPS_FIELD=fps
DURATION_FIELD=duration_seconds
STEPS_FIELD=steps
CFG_FIELD=cfg
SEED_FIELD=seed

# Video defaults
WIDTH=832
HEIGHT=480
FPS=16
DURATION=5
STEPS=25
CFG=5
SEED=-1

# Polling
POLL_INTERVAL=5
TIMEOUT=600

# Local project paths
OUTPUT_DIR=outputs
CLIP_INDEX=data/clips_index.json

# MiniMax (set PROVIDER=minimax)
# MINIMAX_API_KEY=
# MINIMAX_API_BASE=https://api.minimax.io/v1
# MINIMAX_MODEL=MiniMax-Hailuo-2.3
# MINIMAX_RESOLUTION=
# MINIMAX_PROMPT_OPTIMIZER=true

# RunPod (legacy - set PROVIDER=runpod to use)
# RUNPOD_API_KEY=
# RUNPOD_MODE=serverless
# RUNPOD_ENDPOINT_ID=
# SERVERLESS_BASE_URL=https://api.runpod.ai/v2
